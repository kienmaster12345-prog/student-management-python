def student_management_menu(sm):
    while True:
        print("\n--- QUẢN LÝ SINH VIÊN ---")
        print("1. Thêm sinh viên mới")
        print("2. Sửa thông tin sinh viên")
        print("3. Xóa sinh viên")
        print("4. Xem danh sách tất cả")
        print("0. Quay lại")
        choice = input("Chọn: ")
        if choice == "1":
            print("bạn có muốn thêm sinh viên mới?") 
            print("1. Có")
            print("2. Không")
            a = input("vui lòng nhập: ").strip()
            if a == "2":
                print("Đã hủy bỏ thao tác.")
                continue 
            while True:
                sid = input("Mã số sinh viên (VD: SE210910): ").strip().upper()

                try:
                    from utils.validator import is_valid_id
                    if not is_valid_id(sid):
                        raise ValueError("Mã số sinh viên không hợp lệ (VD: SE210910)")

                    if sm.search_by_id(sid):
                        print(f"Lỗi: Mã số {sid} đã tồn tại trong hệ thống! Vui lòng nhập lại từ đầu.")
                        continue  
                    break
                except ValueError as e:
                    print(f"Không hợp lệ: {e}. Vui lòng nhập lại!")

    
            while True:
                name = input("Họ tên: ").strip().upper()
                from utils.validator import is_valid_name

                if is_valid_name(name):
                    break
                print(
                    "Không hợp lệ: Tên chỉ được chứa chữ cái và dấu cách. Vui lòng nhập lại!"
                )

            while True:
                try:
                    day = int(input("Ngày sinh: "))
                    from utils.validator import is_valid_day

                    if not is_valid_day(day):
                        raise ValueError("Ngày sinh phải từ 1 đến 31")
                    break
                except ValueError as e:
                    print(f"Không hợp lệ: {e}. Vui lòng nhập lại!")

            while True:
                try:
                    month = int(input("Tháng sinh: "))
                    from utils.validator import is_valid_month

                    if not is_valid_month(month):
                        raise ValueError("Tháng sinh phải từ 1 đến 12")
                    break
                except ValueError as e:
                    print(f"Không hợp lệ: {e}. Vui lòng nhập lại!")

            while True:
                try:
                    year = int(input("Năm sinh (1990-2010): "))
                    from utils.validator import is_valid_year

                    if not is_valid_year(year):
                        raise ValueError("Năm sinh phải từ 1990 đến 2010")
                    break
                except ValueError as e:
                    print(f"Không hợp lệ: {e}. Vui lòng nhập lại!")

            while True:
                major = input("Ngành học: ").strip().upper()
                from utils.validator import is_valid_major

                if is_valid_major(major):
                    break
                print("Không hợp lệ: Ngành học chỉ gồm chữ cái. Vui lòng nhập lại!")

            try:
                student = Student(sid, name, day, month, year, major)
                sm.add_student(student)
                print("\n Thêm sinh viên thành công!")
                sm.show_all()
            except Exception as e:
                print(f"Lỗi hệ thống: {e}")
        elif choice == "2":
            print("bạn có muốn sửa thông tin sinh viên?") 
            print("1. Có")
            print("2. Không")
            a = input("vui lòng nhập: ").strip()
            if a == "2":
                print("Đã hủy bỏ thao tác.")
                continue 
            
            sid = input("Nhập mã số sinh viên cần sửa: ")
            try:
                new_name = input(
                    "Tên mới (bỏ trống nếu không đổi): "
                    ).strip().upper()
                new_day = input(
                    "Ngày sinh mới (bỏ trống nếu không đổi): "
                    ).strip()
                new_month = input(
                    "Tháng sinh mới (bỏ trống nếu không đổi): "
                    ).strip()
                new_year = input(
                    "Năm sinh mới (bỏ trống nếu không đổi): "
                    ).strip()
                new_major = input(
                    "Ngành mới (bỏ trống nếu không đổi): "
                    ).strip()
                sm.edit_student(
                    sid,
                    new_name if new_name else None,
                    int(new_day) if new_day else None,
                    int(new_month) if new_month else None,
                    int(new_year) if new_year else None,
                    new_major if new_major else None,
                )
                print("Cập nhật thành công!")
            except Exception as e:
                print(f"Lỗi: {e}")
        
        
        elif choice == "3":
            print("bạn có muốn xóa sinh viên?") 
            print("1. Có")
            print("2. Không")
            a = input("vui lòng nhập: ").strip()
            if a == "2":
                print("Đã hủy bỏ thao tác.")
                continue 
            sid = input("Nhập mã số sinh viên cần xóa: ").strip().upper()
            try:
                sm.delete_student(sid)
                print("Xóa thành công!")
            except Exception as e:
                print(f"Lỗi: {e}")
        
        
        elif choice == "4":
            sm.show_all()
        elif choice == "0":
            break
        else:
            print("Lựa chọn không hợp lệ.")


