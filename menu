def search_menu(sm):
    while True:
        print("\n--- TÌM KIẾM SINH VIÊN ---")
        print("1. Theo tên (chứa chuỗi)")
        print("2. Theo mã số chính xác")
        print("0. Quay lại")
        choice = input("Chọn: ")
        if choice == "1":
            keyword = input("Nhập tên (hoặc một phần): ").upper()
            results = sm.search_by_name(keyword)
            if results:
                for s in results:
                    print(s)
            else:
                print("Không tìm thấy.")
        elif choice == "2":
            sid = input("Nhập mã số: ").upper()
            results = sm.search_by_id(sid)
            if results:
                print(results[0])
            else:
                print("Không tìm thấy.")
        elif choice == "0":
            break
        else:
            print("Sai lựa chọn.")

