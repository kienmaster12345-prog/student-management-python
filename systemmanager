from models.student import Student
from utils.file_handler import FileHandler


class SystemManager:
    def __init__(self):
        self.__students = []  # private

    # --- Public methods ---
    def add_student(self, student: Student):
        if self.__find_by_id(student.student_id):
            raise ValueError(f"Mã số {student.student_id} đã tồn tại!")
        self.__students.append(student)

    def edit_student(
        self,
        student_id,
        new_name=None,
        new_day=None,
        new_month=None,
        new_year=None,
        new_major=None,
    ):
        student = self.__find_by_id(student_id)
        if not student:
            raise KeyError(f"Không tìm thấy sinh viên có mã {student_id}")
        if new_name:
            student.name = new_name
        if new_day:
            student.day = new_day
        if new_month:
            student.month = new_month
        if new_year:
            student.year = new_year
        if new_major:
            student.major = new_major

    def delete_student(self, student_id):
        student = self.__find_by_id(student_id)
        if not student:
            raise KeyError(f"Không tìm thấy sinh viên có mã {student_id}")
        self.__students.remove(student)

    def show_all(self):
        if not self.__students:
            print("Danh sách trống.")
        else:
            print("\n===== DANH SÁCH SINH VIÊN =====")
            for idx, s in enumerate(self.__students, 1):
                print(f"{idx}. {s}")
            print(f"Tổng số: {len(self.__students)} sinh viên")

    def search_by_name(self, keyword):
        keyword_lower = keyword.lower()
        return [s for s in self.__students if keyword_lower in s.name.lower()]

    def search_by_id(self, student_id):
        found = self.__find_by_id(student_id)
        return [found] if found else []

    def sort_by_gpa(self, reverse=True):
        self.__students.sort(key=lambda s: s.gpa, reverse=reverse)

    def sort_by_name(self):
        self.__students.sort(
            key=lambda s: s.name.split()[-1].lower() if s.name.strip() else ""
        )

    def sort_by_birth_year(self):
        self.__students.sort(key=lambda s: s.year)

    def save_to_file(self, filename="students.txt"):
        fh = FileHandler(filename)
        lines = [s.to_file_string() for s in self.__students]
        fh.rewrite_lines(lines)
        print(f"Đã lưu {len(self.__students)} sinh viên vào {filename}")

    def load_from_file(self, filename="students.txt"):
        fh = FileHandler(filename)
        lines = fh.read_lines()
        self.__students.clear()
        for line in lines:
            if line.strip():
                try:
                    student = Student.from_file_string(line)
                    self.__students.append(student)
                except Exception as e:
                    print(f"Bỏ qua dòng lỗi: {line.strip()} - {e}")
        print(f"Đã tải {len(self.__students)} sinh viên từ {filename}")

    def get_overall_gpa(self):
        if not self.__students:
            return 0.0
        total = sum(s.gpa for s in self.__students)
        return round(total / len(self.__students), 2)

    # --- Private helper method ---
    def __find_by_id(self, student_id):
        for s in self.__students:
            if s.student_id == student_id:
                return s
        return None

