
from system_manager import SystemManager
sm = SystemManager()

while True:
    print("\n===== MENU =====")
    print("6. Sửa điểm sinh viên")
    print("7. Xóa sinh viên")
    print("8. Lưu file")
    print("9. kiếm tên sinh viên")
    print("10. kiếm MSSV sinh viên")
    print("11. tổng trung bình điểm gpa")
    print("12.sắp xếp gọn gàng lại")

    choice = input("Chọn: ")

  

    if choice == "1":
        student_id = input("Nhập MSSV cần sửa: ")
        sm.edit_student(student_id)
        sm.sort_students_by_name()

    elif choice == "2":
        student_id = input("Nhập tên hoặc MSSV cần xóa: ")
        sm.delete_student(student_id)

    elif choice == "3":
        sm.save_to_file()

    elif choice == "4":
        name = input("Nhập tên sinh viên cần tìm: ")
        results = sm.search_by_name(name)
        print("\n[Kết quả] Tìm thấy sinh viên tương thích:")
        for idx, s in enumerate(results, 1):
            print(f"{idx}. {s}")


    elif choice == "5":
        mssv = input("nhập MSSV để tìm kiếm:")
        results = sm.search_by_id(mssv)
        if results:
            print(f"\n[Kết quả] Tìm thấy sinh viên: {results[0]}")
        else:
            print("sinh viên không có trong danh sách")


    elif choice == "6":
        results = sm.get_overall_gpa()

    elif choice == "7":
        results = sm.sort_students_by_name

    elif choice == "0":
        sm.save_to_file()
        print("Thoát chương trình.")
        break

    else:
        print("Lựa chọn không hợp lệ!")
