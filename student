import json
from utils.validator import (
    is_valid_id,
    is_valid_name,
    is_valid_day,
    is_valid_month,
    is_valid_year,
    is_valid_major,
    is_valid_score,
)


class Student:
    def __init__(self, student_id, name, day, month, year, major, scores=None, gpa=0.0):
        # private attributes
        self.__student_id = None
        self.__name = None
        self.__day = None
        self.__month = None
        self.__year = None
        self.__major = None
        self.__scores = None
        self.__gpa = None

        # set thông qua setter (có validation)
        self.student_id = student_id
        self.name = name
        self.day = day
        self.month = month
        self.year = year
        self.major = major
        self.scores = scores if scores is not None else {}
        self.__gpa = gpa if gpa else self.calculate_gpa()

    # --- Public getters / setters (vì cần truy cập từ bên ngoài) ---
    @property
    def student_id(self):
        return self.__student_id

    @student_id.setter
    def student_id(self, value):
        if not is_valid_id(value):
            raise ValueError("Mã số sinh viên không hợp lệ (VD: SE210910)")
        self.__student_id = value

    @property
    def name(self):
        return self.__name

    @name.setter
    def name(self, value):
        if not is_valid_name(value):
            raise ValueError("Tên chỉ được chứa chữ cái và dấu cách")
        self.__name = value.strip()

    @property
    def day(self):
        return self.__day

    @day.setter
    def day(self, value):
        if not is_valid_day(value):
            raise ValueError("Ngày sinh phải từ 1 đến 31")
        self.__day = value

    @property
    def month(self):
        return self.__month

    @month.setter
    def month(self, value):
        if not is_valid_month(value):
            raise ValueError("Tháng sinh phải từ 1 đến 12")
        self.__month = value

    @property
    def year(self):
        return self.__year

    @year.setter
    def year(self, value):
        if not is_valid_year(value):
            raise ValueError("Năm sinh phải từ 1990 đến 2010")
        self.__year = value

    @property
    def major(self):
        return self.__major

    @major.setter
    def major(self, value):
        if not is_valid_major(value):
            raise ValueError("Ngành học chỉ gồm chữ cái")
        self.__major = value.strip()

    @property
    def scores(self):
        return self.__scores

    @scores.setter
    def scores(self, value):
        if not isinstance(value, dict):
            raise ValueError("Điểm số phải là một dictionary")
        self.__scores = value

    @property
    def gpa(self):
        return self.__gpa

    # --- Public methods ---
    def add_score(self, subject, score):
        if not is_valid_score(score):
            raise ValueError("Điểm phải nằm trong khoảng 0-10")
        self.__scores[subject] = score
        self.__gpa = self.calculate_gpa()

    def update_score(self, subject, new_score):
        if subject not in self.__scores:
            raise KeyError(f"Môn '{subject}' chưa có trong bảng điểm")
        self.add_score(subject, new_score)


    def update_subject_name(self, old_subject, new_subject):
        if old_subject not in self.__scores:
            raise KeyError(f"Môn '{old_subject}' chưa có trong bảng điểm")
        if not new_subject.strip():
            raise ValueError("Tên môn học mới không được để trống")
        
        
        score = self.__scores.pop(old_subject)
        self.__scores[new_subject.strip()] = score

    def calculate_gpa(self):
        if not self.__scores:
            return 0.0
        return round(sum(self.__scores.values()) / len(self.__scores), 2)

    def to_file_string(self):
        scores_json = json.dumps(self.__scores, ensure_ascii=False)
        return f"{self.__student_id}|{self.__name}|{self.__day}|{self.__month}|{self.__year}|{self.__major}|{scores_json}|{self.__gpa}\n"

    @classmethod
    def from_file_string(cls, line):
        parts = line.strip().split("|")
        if len(parts) != 8:
            raise ValueError("Dòng dữ liệu không hợp lệ")
        sid, name, day, month, year, major, scores_json, gpa = parts
        scores = json.loads(scores_json) if scores_json != "{}" else {}
        return cls(
            sid, name, int(day), int(month), int(year), major, scores, float(gpa)
        )

    def __str__(self):
        birth = f"{self.__day}/{self.__month}/{self.__year}"
        return f"{self.__student_id} | {self.__name} | {birth} | {self.__major} | GPA: {self.__gpa:.2f}"

