from services.system_manager import SystemManager
from services.score_manager import ScoreManager
from ui.menu import (
    display_main_menu,
    student_management_menu,
    score_management_menu,
    search_menu,
    sort_menu,
)


def main():
    sm = SystemManager()
    scm = ScoreManager(sm)

    try:
        sm.load_from_file()
    except FileNotFoundError:
        print("Chưa có file dữ liệu. Bắt đầu với danh sách trống.")
    except Exception as e:
        print(f"Lỗi khi tải file: {e}")

    while True:
        choice = display_main_menu()
        if choice == "1":
            student_management_menu(sm)
        elif choice == "2":
            score_management_menu(sm, scm)
        elif choice == "3":
            search_menu(sm)
        elif choice == "4":
            sort_menu(sm)
        elif choice == "5":
            gpa = sm.get_overall_gpa()
            print(f"GPA trung bình toàn lớp: {gpa:.2f}")
        elif choice == "6":
            sm.save_to_file()
        elif choice == "7":
            sm.load_from_file()
        elif choice == "0":
            while True:
                confirm = input("Bạn có muốn lưu dữ liệu trước khi thoát? (y/n): ").strip().lower()
                if confirm in ["y", "n"]:
                    break
                print("Lựa chọn không hợp lệ! Vui lòng chỉ nhập 'y' (Có) hoặc 'n' (Không).")
            
            if confirm == "y":
                sm.save_to_file()
                
            print("Tạm biệt!")
            break
        else:
            print("Vui lòng chọn số từ 0 đến 7.")


if __name__ == "__main__":
    main()

