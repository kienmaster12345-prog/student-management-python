import os


class FileHandler:
    def __init__(self, file_path):
        self.__file_path = file_path  # private

    def read_lines(self):
        if not self.__file_exists():
            return []
        with open(self.__file_path, "r", encoding="utf-8") as f:
            return f.readlines()

    def write_lines(self, lines):
        with open(self.__file_path, "a", encoding="utf-8") as f:
            for line in lines:
                f.write(line)
            f.flush()

    def rewrite_lines(self, lines):
        with open(self.__file_path, "w", encoding="utf-8") as f:
            for line in lines:
                f.write(line)

    def __file_exists(self):  # private method
        return os.path.exists(self.__file_path)
